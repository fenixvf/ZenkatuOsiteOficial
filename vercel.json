{
  "version": 2,
  "buildCommand": "pnpm -w run build:render",
  "outputDirectory": "artifacts/zenkatu/dist/public",
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/index" }
  ],
  "functions": {
    "api/index.js": {
      "runtime": "nodejs20.x",
      "maxDuration": 30
    }
  }
}
